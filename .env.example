# JARVIS environment configuration — copy this file to ".env" and fill in.
#
#   cp .env.example .env      (then edit .env)
#
# JARVIS reads these from the OS environment. On Windows you can either set
# them as User environment variables, or keep them in a local ".env" (which is
# gitignored and never committed). Leave anything you don't use blank — every
# integration degrades gracefully when its key/credential is absent.
#
# NOTHING in this file is secret — it's a template. Put REAL values only in
# your local .env (or your OS env), never here.

# ─────────────────────────── REQUIRED ───────────────────────────
# Anthropic Claude API key — the primary brain. Get one at
# https://console.anthropic.com/ . Without it, JARVIS falls back to a local
# Ollama model if you have one installed (see README), otherwise it can't think.
ANTHROPIC_API_KEY=

# The name JARVIS should call you, and recognise as the owner (calendar
# "is this me?" checks, voice-ID default, briefing personalisation).
JARVIS_USER_NAME=

# ─────────────────────── WAKE WORD (optional) ───────────────────
# Picovoice Porcupine access key for hands-free "Hey JARVIS" wake detection.
# Free key at https://console.picovoice.ai/ . Without it, use push-to-talk /
# the inject path instead.
PORCUPINE_ACCESS_KEY=

# ──────────── REALTIME VOICE / NEURAL WAKE (optional) ───────────
# Low-latency streaming voice. "turn_based" (default) or "realtime"; realtime
# needs the optional RealtimeSTT + RealtimeTTS packages and falls back
# automatically if they're absent. (Also settable in the Settings GUI.)
JARVIS_VOICE_MODE=
# Neural wake-word detector in standby (openWakeWord) instead of the
# Whisper-substring path. Truthy (1/true/on) = on; needs the openwakeword pkg.
JARVIS_WAKE_WORD_AUTOSTART=

# ─────────────────── UPDATE CHECKS (optional) ───────────────────
# GitHub token so the boot-time update check can reach this repo's Releases API
# (read-only "Contents" scope is enough) — needed only when the repo is PRIVATE.
# JARVIS_GITHUB_TOKEN wins over GITHUB_TOKEN; without either, update checks are
# silently skipped (nothing breaks). Toggle the nudge via UPDATE_CHECK_ENABLED
# in core/config.py.
JARVIS_GITHUB_TOKEN=

# ──────────────────── CLOUD TEXT-TO-SPEECH (optional) ───────────
# JARVIS defaults to free edge-tts. Set these only for premium voices.
AZURE_TTS_KEY=
AZURE_TTS_REGION=
ELEVENLABS_API_KEY=
# Local XTTS voice cloning (optional): TTS_BACKEND=xtts plus a sample wav.
TTS_BACKEND=
XTTS_VOICE_SAMPLE=
XTTS_LANGUAGE=

# ──────────────── BAMBU LAB 3D PRINTER (optional) ───────────────
# From the printer: Settings -> Network (LAN Only) for IP + access code, and
# Bambu Handy -> Firmware for the serial. Leave blank to disable monitoring.
BAMBU_PRINTER_IP=
BAMBU_ACCESS_CODE=
BAMBU_SERIAL=

# ───────────────────── SMART HOME (optional) ────────────────────
GOVEE_API_KEY=
# TP-Link Deco router (only used by the optional network_deco skill):
DECO_HOST=
DECO_PASSWORD=

# ───────────────────────── OBS (optional) ──────────────────────
# OBS Studio WebSocket (Tools -> WebSocket Server Settings).
OBS_HOST=
OBS_PORT=
OBS_PASSWORD=

# ─────────────── PHONE BRIDGE / NOTIFICATIONS (optional) ────────
# Pick ONE channel. Telegram: token from @BotFather, your id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
# ntfy.sh push (self-host or public):
NTFY_TOPIC=
NTFY_HOST=
# Pushover:
PUSHOVER_TOKEN=
PUSHOVER_USER=

# ───────────────────── MODEL OVERRIDES (optional) ──────────────
# Pin specific models; sensible defaults are used when blank.
CLAUDE_MODEL=
JARVIS_LOCAL_LLM_MODEL=
BROWSER_AGENT_MODEL=
PHONE_BRIDGE_MODEL=

# ──────────────── LOCAL OLLAMA / VRAM SAFETY (recommended) ──────
# Cap how many models Ollama keeps RESIDENT in VRAM at once. On a single 24 GB
# card the baseline 30B brain alone is ~19-21 GB, so if Ollama co-loads a second
# model (e.g. the local vision VLM) it over-commits and CUDA-OOM bricks the GPU.
# Setting this to 1 makes Ollama EVICT the resident model before loading another
# instead of co-loading — no OOM. JARVIS sets and persists this for you at boot
# (User env), but the OLLAMA SERVER only reads it at ITS OWN startup: if a server
# is already running you must restart Ollama ONCE for it to take effect (quit the
# tray icon, or `Restart-Service ollama`, or kill ollama.exe). Until then JARVIS's
# runtime guard still refuses the 2nd-model load, so the GPU is safe either way.
OLLAMA_MAX_LOADED_MODELS=1
# Override for the runtime guard above: set to 1/true/on ONLY on a box with the
# VRAM headroom to hold the big text model AND the vision model at once. With it
# set, JARVIS will allow co-loading the local VLM even while the 30B is resident.
JARVIS_ALLOW_VLM_COLOAD=

# ─────────────────────── MISC (optional) ───────────────────────
# Daily $ ceiling for the background deep-audit diagnostic (default modest).
JARVIS_DEEP_AUDIT_BUDGET_USD=
# Which morning routine the chain prefers (arrival | briefing | handoff).
DEFAULT_MORNING_SKILL=
# Voice-ID default speaker name (falls back to JARVIS_USER_NAME).
VOICE_ID_DEFAULT_USER=
